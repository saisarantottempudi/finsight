DATABASE_URL=postgresql+asyncpg://finsight:finsight@localhost:5432/finsight
SECRET_KEY=changeme-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
LOG_LEVEL=INFO
OTEL_ENDPOINT=http://jaeger:4317
SYMBOLS=AAPL,GOOGL,MSFT,JPM,GS
INTERVAL_SECONDS=60
MODEL_PATH=/models/fraud_detector.pkl

# Grafana Cloud (fill in after signing up at grafana.com)
GRAFANA_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_PROM_USER=
GRAFANA_API_KEY=
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
